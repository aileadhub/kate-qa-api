# ── Nifty OAuth app credentials ─────────────────────────────
# Get from: Nifty → Settings → Developer → your app
NIFTY_CLIENT_ID=
NIFTY_CLIENT_SECRET=

# Your Vercel deployment URL + callback path (fill in after first deploy)
NIFTY_REDIRECT_URI=https://your-app.vercel.app/api/nifty/oauth/callback

# ── API protection ───────────────────────────────────────────
# Any long random string — this is what Kate puts in QA_API_TOKEN in boosted-qa/.env
# Generate one: openssl rand -hex 32
QA_API_TOKEN=

# ── Upstash Redis (auto-filled by Vercel when you add the Upstash Redis integration) ─
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Vercel Cron secret (auto-filled by Vercel) ───────────────
CRON_SECRET=
